{
  "expo": {
    "name": "MVG Computación",
    "slug": "mvg-computacion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mvg",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Tomar foto de evidencia del trabajo realizado",
        "NSPhotoLibraryUsageDescription": "Adjuntar foto de evidencia desde tu galería"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B1121"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B1121"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Adjuntar foto de evidencia desde tu galería",
          "cameraPermission": "Tomar foto de evidencia del trabajo realizado"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
